PORT=8000
MONGO_URI=mongodb://localhost:27017/openid-mini
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=1h
ID_TOKEN_EXPIRY=1h
ISSUER=http://localhost:8000
OIDC_KEY_ID=openid-mini-dev-key
# Optional production key. Use escaped newlines if storing PEM in one env value.
# OIDC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# OIDC_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Optional X.509 certificate for JWKS x5c.
# OIDC_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
